# ============================================================
# Variáveis do site NEXUS (landing + Estúdio 3D + Portal do Cliente).
# Copie para `.env.local` e ajuste. Em produção, defina na Vercel.
# ============================================================

# --- Produção (nuvem) ---
# Relay de tempo real (colaboração 3D) hospedado no Render.
VITE_COLLAB_WS_URL=wss://linear-realtime-relay.onrender.com
# API pública do CRM (leads, propostas e Portal do Cliente).
VITE_CRM_API_BASE_URL=https://crm-marcenaria.vercel.app/api

# --- Dev 100% local (use no .env.local) ---
# CRM rodando na sua máquina (server Express em D:\crmMarcenaria):
#   VITE_CRM_API_BASE_URL=http://localhost:3001/api
# Relay rodando no próprio site (`npm run server`):
#   VITE_COLLAB_WS_URL=ws://localhost:8787
